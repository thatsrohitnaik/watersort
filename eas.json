{
  "cli": {
    "version": ">= 14.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "gradleProperties": {
          "org.gradle.jvmargs": "-Xmx4g -XX:MaxMetaspaceSize=512m -XX:+UseParallelGC -XX:+HeapDumpOnOutOfMemoryError",
          "org.gradle.parallel": "true",
          "org.gradle.caching": "true"
        }
      }
    }
  },
  "submit": {
    "production": {}
  }
}
