{
  "name": "watersortgame",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.3.8",
    "@react-navigation/native-stack": "^7.17.10",
    "babel-preset-expo": "^57.0.2",
    "expo": "~57.0.6",
    "expo-av": "^16.0.8",
    "expo-build-properties": "~57.0.5",
    "expo-haptics": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.10.0",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^14.0.1",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "react-test-renderer": "^19.2.7",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/src/__tests__/mocks/"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "babel-jest",
        {
          "configFile": "./babel.config.js"
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(zustand|react-native|@react-native|@react-navigation|expo-av|expo-modules-core|expo-haptics|react-native-reanimated|react-native-gesture-handler|react-native-screens|react-native-safe-area-context|react-native-worklets|@expo)/)"
    ]
  },
  "private": true
}
